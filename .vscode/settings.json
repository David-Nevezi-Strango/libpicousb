{
    // C/C++ IntelliSense: ignore the RP2040 copy of the SDK so navigation
    // (Go to Definition / Find References / workspace symbols) only resolves
    // to the RP2350 headers this project actually builds against.
    "C_Cpp.files.exclude": {
        "**/pico-sdk/src/rp2040/**": true
    },
    "search.exclude": {
        "**/pico-sdk/src/rp2040/**": true
    },
    // Point IntelliSense at the real compiler include paths for this build.
    // Generated by CMake with -DCMAKE_EXPORT_COMPILE_COMMANDS=ON.
    "C_Cpp.default.compileCommands": "${workspaceFolder}/build_pico2_w/compile_commands.json"
}
